---
import { getCollection,type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";

const title = "Zahrawi | Modern Dentistry Blog";
const description = "Modern Dentistry Blog";

// const allPosts: CollectionEntry<"blog">[] = await getCollection("blog");

export async function getAllPosts() {
  const posts = await getCollection("blog");
  return posts.sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );
}

const allPosts: CollectionEntry<"blog">[] = await getAllPosts();

---

<BaseLayout title={title} description={description}>
  <p>This is where I will post about my journey learning Astro.</p>
  <div class="mt-12 max-w-lg mx-auto grid gap-5 lg:grid-cols-3 lg:max-w-none">
    {allPosts.map((post) =>  <ArticleCard postObj={post} />)}
  </div>
</BaseLayout>
