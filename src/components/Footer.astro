<!-- Footer -->
<footer class="bg-gray-800" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:py-16 lg:px-8">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      <div class="space-y-8 xl:col-span-1">
        <div class="flex items-center">
          <i class="fas fa-tooth text-teal-400 text-2xl mr-2"></i>
          <h3 class="text-2xl font-bold text-teal-400">Zahrawi</h3>
        </div>
        <p class="text-gray-300 text-base">
          Bringing you the latest in dental health education, research, and professional insights. Your trusted source for evidence-based oral healthcare information since 2022.
        </p>
        <div class="flex space-x-6">
          <a href="#" class="text-gray-400 hover:text-teal-400 transition-colors duration-300">
            <span class="sr-only">Facebook</span>
            <i class="fab fa-facebook-f text-xl"></i>
          </a>
          <a href="#" class="text-gray-400 hover:text-teal-400 transition-colors duration-300">
            <span class="sr-only">Instagram</span>
            <i class="fab fa-instagram text-xl"></i>
          </a>
          <a href="#" class="text-gray-400 hover:text-teal-400 transition-colors duration-300">
            <span class="sr-only">Twitter</span>
            <i class="fab fa-twitter text-xl"></i>
          </a>
          <a href="#" class="text-gray-400 hover:text-teal-400 transition-colors duration-300">
            <span class="sr-only">YouTube</span>
            <i class="fab fa-youtube text-xl"></i>
          </a>
          <a href="#" class="text-gray-400 hover:text-teal-400 transition-colors duration-300">
            <span class="sr-only">LinkedIn</span>
            <i class="fab fa-linkedin-in text-xl"></i>
          </a>
        </div>
      </div>
      <div class="mt-12 grid grid-cols-2 gap-8 xl:mt-0 xl:col-span-2">
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <div>
            <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase">
              Content
            </h3>
            <ul role="list" class="mt-4 space-y-4">
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Latest Articles
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Popular Topics
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Featured Stories
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Dental Tips
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Video Library
                </a>
              </li>
            </ul>
          </div>
          <div class="mt-12 md:mt-0">
            <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase">
              Categories
            </h3>
            <ul role="list" class="mt-4 space-y-4">
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Preventive Care
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Cosmetic Dentistry
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Pediatric Dentistry
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Restorative Procedures
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Dental Technology
                </a>
              </li>
            </ul>
          </div>
        </div>
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <div>
            <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase">
              Support
            </h3>
            <ul role="list" class="mt-4 space-y-4">
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  FAQ
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Contact Us
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Find a Dentist
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Emergency Care
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Dental Insurance
                </a>
              </li>
            </ul>
          </div>
          <div class="mt-12 md:mt-0">
            <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase">
              Company
            </h3>
            <ul role="list" class="mt-4 space-y-4">
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  About Us
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Our Team
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Careers
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Partnerships
                </a>
              </li>
              <li>
                <a href="#" class="text-base text-gray-300 hover:text-white transition-colors duration-300">
                  Advertise With Us
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Newsletter Subscription -->
    <div class="mt-12 border-t border-gray-700 pt-8">
      <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase">
        Subscribe to our newsletter
      </h3>
      <p class="mt-2 text-base text-gray-300">
        Get the latest dental health tips and articles delivered to your inbox.
      </p>
      <form class="mt-4 sm:flex sm:max-w-md">
        <label for="email-address" class="sr-only">Email address</label>
        <input type="email" name="email-address" id="email-address" autocomplete="email" required class="appearance-none min-w-0 w-full bg-gray-700 border border-gray-600 rounded-md py-2 px-4 text-base text-gray-300 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500 focus:placeholder-gray-400" placeholder="Enter your email">
        <div class="mt-3 rounded-md sm:mt-0 sm:ml-3 sm:flex-shrink-0">
          <button type="submit" class="w-full bg-teal-500 border border-transparent rounded-md py-2 px-4 flex items-center justify-center text-base font-medium text-white hover:bg-teal-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-gray-800 focus:ring-teal-500">
            Subscribe
          </button>
        </div>
      </form>
    </div>

    <!-- Bottom section with copyright and links -->
    <div class="mt-8 border-t border-gray-700 pt-8 md:flex md:items-center md:justify-between">
      <div class="flex space-x-6 md:order-2">
        <a href="#" class="text-gray-400 hover:text-gray-300 transition-colors duration-300">
          Privacy Policy
        </a>
        <a href="#" class="text-gray-400 hover:text-gray-300 transition-colors duration-300">
          Terms of Use
        </a>
        <a href="#" class="text-gray-400 hover:text-gray-300 transition-colors duration-300">
          Cookie Policy
        </a>
        <a href="#" class="text-gray-400 hover:text-gray-300 transition-colors duration-300">
          Accessibility
        </a>
      </div>
      <p class="mt-8 text-base text-gray-400 md:mt-0 md:order-1">
        &copy; 2025 Zahrawi Dental Blog. All rights reserved.
      </p>
    </div>
  </div>
</footer>
