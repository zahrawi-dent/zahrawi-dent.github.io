---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = "Page Not Found | Zahrawi";
const description = "404 page not found";
---

<BaseLayout title={title} description={description}>
  <main class="flex flex-col items-center justify-center min-h-[70vh] px-4 py-12 text-center">
    <div class="w-64 h-64 mb-8">
      <!-- SVG of a sad tooth -->
      <svg viewBox="0 0 200 200" class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <path d="M100 25C85 25 75 35 65 35C55 35 45 30 40 45C35 60 35 75 35 95C35 115 40 145 55 165C70 185 85 185 100 185C115 185 130 185 145 165C160 145 165 115 165 95C165 75 165 60 160 45C155 30 145 35 135 35C125 35 115 25 100 25Z" fill="#F5F5F5" stroke="#6B7280" stroke-width="4"/>
        <!-- Sad face -->
        <circle cx="75" cy="90" r="7" fill="#6B7280"/>
        <circle cx="125" cy="90" r="7" fill="#6B7280"/>
        <path d="M70 130C80 120 120 120 130 130" stroke="#6B7280" stroke-width="4" fill="none"/>
      </svg>
    </div>
    
    <h1 class="text-5xl font-bold text-teal-600 mb-4">404</h1>
    <h2 class="text-3xl font-semibold text-teal-900 mb-6">Oops! This page is missing</h2>
    <p class="text-xl text-gray-600 mb-8 max-w-lg">
      Looks like this page has been extracted! Don't worry, our dental team is on the case.
    </p>
    
    <div class="space-y-6 mb-12">
      <p class="text-lg text-gray-700">You might want to check for:</p>
      <ul class="text-left text-gray-600 inline-block mx-auto">
        <li class="flex items-center mb-3">
          <svg class="w-5 h-5 mr-2 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Typos in the URL
        </li>
        <li class="flex items-center mb-3">
          <svg class="w-5 h-5 mr-2 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          An outdated link
        </li>
        <li class="flex items-center">
          <svg class="w-5 h-5 mr-2 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          A page that was moved
        </li>
      </ul>
    </div>
    
    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/" class="px-6 py-3 bg-teal-500 text-black  font-medium rounded-lg hover:bg-teal-700 transition-colors">
        Return Home
      </a>
      <a href="/blog" class="px-6 py-3 bg-gray-200 text-gray-800 font-medium rounded-lg hover:bg-gray-300 transition-colors">
        Browse Articles
      </a>
    </div>
    
    <!-- Astro Island for search functionality -->
    <div class="mt-16 max-w-md w-full" transition:animate="slide">
      <div class="bg-indigo-50  p-6 rounded-lg shadow-sm">
        <h3 class="text-xl font-semibold text-gray-800 mb-4">Looking for something?</h3>
        <form id="search-form" class="flex gap-2" action="/search">
          <input 
            type="text" 
            id="search-input" 
            placeholder="Search our blog..." 
            class="flex-grow px-4 py-2 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-teal-500"
          />
          <button 
            type="submit"
            class="px-4 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition-colors"
          >
            Search
          </button>
        </form>
      </div>
    </div>
  </main>

  <script>
    // Client-side JavaScript for handling the search form
    document.addEventListener('DOMContentLoaded', () => {
      const searchForm = document.getElementById('search-form');
      const searchInput = document.getElementById('search-input');
      
      searchForm?.addEventListener('submit', (e) => {
        e.preventDefault();
        const searchTerm = searchInput?.value.trim();
        if (searchTerm) {
          window.location.href = `/search?q=${encodeURIComponent(searchTerm)}`;
        }
      });
    });
  </script>
</MainLayout>
