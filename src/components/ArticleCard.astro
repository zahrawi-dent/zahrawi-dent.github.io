---
const { post } = Astro.props
---
<div class="flex flex-col rounded-lg shadow-lg overflow-hidden" >
  <div class="flex-shrink-0">
    <img class="h-48 w-full object-cover" src="/api/placeholder/600/400" alt="Teeth Whitening">
  </div>
  <div class="flex-1 bg-white p-6 flex flex-col justify-between">
    <a class="flex-1">
      <p class="text-sm font-medium text-teal-600">
          <!-- iterate over post.tags and display each tag -->
          {post.tags.map((tag:any) => (
            <a class="mr-2 inline-block bg-teal-500 text-white px-3 py-1 rounded-md text-sm font-medium mb-2" href={`/tags/${tag}`}>{tag}</a>
          ))}
      </p>
      <a href=`${post.url}` class="block mt-2">
        <p class="text-xl font-semibold text-gray-900">
          {post.title}
        </p>
        <p class="mt-3 text-base text-gray-500">
        {post.description}
        </p>
      </a>
    </div>
    <div class="mt-6 flex items-center">
      <div class="flex-shrink-0">
        <img class="h-10 w-10 rounded-full" src="/api/placeholder/100/100" alt="Author">
      </div>
      <div class="ml-3">
        <p class="text-sm font-medium text-gray-900">
            {post.author}
        </p>
        <div class="flex space-x-1 text-sm text-gray-500">
          <time datetime="2025-03-10">Mar 10, 2025</time>
          <span aria-hidden="true">&middot;</span>
          <span>6 min read</span>
        </div>
      </div>
    </div>
  </div>
</div>
