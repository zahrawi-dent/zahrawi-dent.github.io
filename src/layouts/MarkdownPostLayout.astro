---
import { formatDate } from "../utils";
import BaseLayout from "./BaseLayout.astro";
import "../styles/markdown.css";

const { frontmatter } = Astro.props;
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <!-- Blog Post Component -->
  <article
    class="bg-white rounded-lg shadow-md overflow-hidden max-w-4xl mx-auto my-8"
  >
    <!-- Featured Image -->
    <div class="relative">
      <img
        src={frontmatter.image.url}
        alt={frontmatter.image.alt}
        class="w-full h-64 md:h-96 object-cover"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"
      >
      </div>
      <div class="absolute bottom-0 left-0 p-6">
        {
          frontmatter.tags.map((tag: any) => (
            <a
              class="mr-2 inline-block bg-teal-500 text-white px-3 py-1 rounded-md text-sm font-medium mb-2"
              href={`/tags/${tag}`}
            >
              {tag}
            </a>
          ))
        }
        <h1 class="text-3xl md:text-4xl font-bold text-white">
          {frontmatter.title}
        </h1>
      </div>
    </div>

    <!-- Post Meta -->
    <div class="border-b border-gray-200">
      <div class="px-6 py-4 flex items-center justify-between flex-wrap">
        <div class="flex items-center">
          <img
            src="/api/placeholder/100/100"
            alt="Author"
            class="h-10 w-10 rounded-full mr-3"
          />
          <div>
            <p class="text-sm font-medium text-gray-900">
              {frontmatter.author}
            </p>
            <p class="text-xs text-gray-500">
              DDS, Preventive Dentistry Specialist
            </p>
          </div>
        </div>
        <div class="flex items-center mt-2 sm:mt-0">
          <div class="flex items-center text-sm text-gray-500 mr-6">
            <i class="far fa-calendar-alt mr-1"></i>
            <!--TODO: change format  -->
            <time datetime="July 1, 2022"
              >{formatDate(frontmatter.pubDate)}</time
            >
          </div>
          <div class="flex items-center text-sm text-gray-500">
            <i class="far fa-clock mr-1"></i>
            <!-- TODO:  -->
            <span>8 min read</span>
          </div>
        </div>
      </div>
    </div>

    <slot />

    <!-- Social Sharing -->
    <div class="px-6 py-4 border-t border-gray-200">
      <div class="flex items-center justify-between flex-wrap">
        <div class="text-sm font-medium text-gray-900">Share this article:</div>
        <div class="flex space-x-4 mt-2 sm:mt-0">
          <a href="#" class="text-gray-600 hover:text-teal-600">
            <i class="fab fa-facebook-f"></i>
          </a>
          <a href="#" class="text-gray-600 hover:text-teal-600">
            <i class="fab fa-twitter"></i>
          </a>
          <a href="#" class="text-gray-600 hover:text-teal-600">
            <i class="fab fa-linkedin-in"></i>
          </a>
          <a href="#" class="text-gray-600 hover:text-teal-600">
            <i class="fab fa-pinterest"></i>
          </a>
          <a href="#" class="text-gray-600 hover:text-teal-600">
            <i class="far fa-envelope"></i>
          </a>
        </div>
      </div>
    </div>

    <!-- Related Posts -->
    <div class="px-6 py-8 border-t border-gray-200">
      <h3 class="text-xl font-bold text-gray-900 mb-6">Related Articles</h3>
      <div class="grid gap-6 md:grid-cols-2">
        <!-- Related Post 1 -->
        <a href="#" class="group">
          <div class="flex items-center">
            <div
              class="h-16 w-16 bg-gray-100 rounded overflow-hidden flex-shrink-0"
            >
              <img
                src="/api/placeholder/100/100"
                alt="Related Post"
                class="h-full w-full object-cover"
              />
            </div>
            <div class="ml-4">
              <p
                class="text-sm font-medium text-gray-900 group-hover:text-teal-600"
              >
                How to Choose the Right Toothbrush for Your Needs
              </p>
              <p class="text-xs text-gray-500 mt-1">March 10, 2025</p>
            </div>
          </div>
        </a>

        <!-- Related Post 2 -->
        <a href="#" class="group">
          <div class="flex items-center">
            <div
              class="h-16 w-16 bg-gray-100 rounded overflow-hidden flex-shrink-0"
            >
              <img
                src="/api/placeholder/100/100"
                alt="Related Post"
                class="h-full w-full object-cover"
              />
            </div>
            <div class="ml-4">
              <p
                class="text-sm font-medium text-gray-900 group-hover:text-teal-600"
              >
                The Link Between Gum Disease and Heart Health
              </p>
              <p class="text-xs text-gray-500 mt-1">March 5, 2025</p>
            </div>
          </div>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
